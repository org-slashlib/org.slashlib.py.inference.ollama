{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "colored": {
            "()": "colorlog.ColoredFormatter",
            "format": "%(asctime)s - %(log_color)s%(message)s%(reset)s",
            "datefmt": "%Y-%m-%d %H:%M:%S",
            "log_colors": {
                "DEBUG":    "black,thin",
                "INFO":     "white",
                "WARNING":  "yellow",
                "ERROR":    "red",
                "CRITICAL": "red,bg_white"
            },
            "secondary_log_colors": {},
            "style": "%"
        },
        "file": {
            "format": "%(asctime)s - %(levelname)-8s - %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        }
    },
    "handlers": {
        "console": {
            "class": "logging.StreamHandler",
            "level": "DEBUG",
            "formatter": "colored",
            "stream": "ext://sys.stdout"
        }
    },
	"loggers": {
        "org.slashlib.py": {
            "level": "DEBUG",
            "handlers": ["console"],
            "propagate": false
        }
    },	
    "root": {
        "level": "WARNING",
        "handlers": ["console"]
    }
}